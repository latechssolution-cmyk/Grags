# MongoDB Connection URI
# Replace with your actual MongoDB Atlas connection string:
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/graggs?retryWrites=true&w=majority

# Resend (transactional email) API key — used by netlify/functions/send-email.cjs
# to send order status emails. Get this from Resend > API Keys.
# Note: the sending domain (grags.shop) must be verified in Resend's dashboard
# (Domains > Add Domain > add the DNS records they give you) before mail from
# noreply@grags.shop will actually deliver — a brand-new API key does not
# carry over domain verification from a previous Resend account/key.
RESEND_API_KEY=re_...

# For local development with Netlify functions, install Netlify CLI:
# npm install -g netlify-cli
#
# Then run:
# netlify dev
